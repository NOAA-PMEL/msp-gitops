[
  {
    "version": "envds.sampling.system/v1",
    "kind": "PlatformVariableMap",
    "metadata": { "name": "varmap_primary_neph", "sampling_namespace": "${SAMPLING_NAMESPACE}", "platform": "${ENVOPS_PLATFORM_REF}", "valid_config_time": "${NEPH_REVISION_TIME}", "revision": 1 },
    "data": {
      "attributes": { "variablemap_type": "Sensor", "valid_config_time": "${NEPH_REVISION_TIME}" },
      "variablesets": { "main": { "index": { "index_type": "time", "index_value": ${MAIN_VARSET_TIMEBASE} }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" } } } },
      "variables": {
        "scatter_red": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "scat_red": { "source_type": "device", "source_id": "${NEPH_DRIVER}::${NEPH_SN}", "source_variable": "${NEPH_SCAT_R_VAR}" } }, "direct_value": { "source_variable": "scat_red" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "Mm-1" } } },
        "scatter_green": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "scat_green": { "source_type": "device", "source_id": "${NEPH_DRIVER}::${NEPH_SN}", "source_variable": "${NEPH_SCAT_G_VAR}" } }, "direct_value": { "source_variable": "scat_green" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "Mm-1" } } },
        "scatter_blue": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "scat_blue": { "source_type": "device", "source_id": "${NEPH_DRIVER}::${NEPH_SN}", "source_variable": "${NEPH_SCAT_B_VAR}" } }, "direct_value": { "source_variable": "scat_blue" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "Mm-1" } } },
        "backscatter_red": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "bscat_red": { "source_type": "device", "source_id": "${NEPH_DRIVER}::${NEPH_SN}", "source_variable": "${NEPH_BSCAT_R_VAR}" } }, "direct_value": { "source_variable": "bscat_red" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "Mm-1" } } },
        "backscatter_green": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "bscat_green": { "source_type": "device", "source_id": "${NEPH_DRIVER}::${NEPH_SN}", "source_variable": "${NEPH_BSCAT_G_VAR}" } }, "direct_value": { "source_variable": "bscat_green" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "Mm-1" } } },
        "backscatter_blue": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "bscat_blue": { "source_type": "device", "source_id": "${NEPH_DRIVER}::${NEPH_SN}", "source_variable": "${NEPH_BSCAT_B_VAR}" } }, "direct_value": { "source_variable": "bscat_blue" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "Mm-1" } } },
        "neph_sample_temperature": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "sample_T": { "source_type": "device", "source_id": "${NEPH_DRIVER}::${NEPH_SN}", "source_variable": "${NEPH_TEMP_VAR}" } }, "direct_value": { "source_variable": "sample_T" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "degrees_C" } } },
        "neph_sample_rh": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "rh": { "source_type": "device", "source_id": "${NEPH_DRIVER}::${NEPH_SN}", "source_variable": "${NEPH_RH_VAR}" } }, "direct_value": { "source_variable": "rh" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "%" } } },
        "neph_pressure": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "pressure": { "source_type": "device", "source_id": "${NEPH_DRIVER}::${NEPH_SN}", "source_variable": "${NEPH_PRES_VAR}" } }, "direct_value": { "source_variable": "pressure" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "mbar" } } }
      }
    }
  }
]
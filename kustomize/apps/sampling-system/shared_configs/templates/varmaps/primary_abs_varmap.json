      "variables": {
        "absorption_red": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "abs_red": { "source_type": "device", "source_id": "${ABS_DRIVER}::${ABS_SN}", "source_variable": "${ABS_R_VAR}" } }, "direct_value": { "source_variable": "abs_red" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "Mm-1" } } },
        "absorption_green": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "abs_green": { "source_type": "device", "source_id": "${ABS_DRIVER}::${ABS_SN}", "source_variable": "${ABS_G_VAR}" } }, "direct_value": { "source_variable": "abs_green" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "Mm-1" } } },
        "absorption_blue": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "abs_blue": { "source_type": "device", "source_id": "${ABS_DRIVER}::${ABS_SN}", "source_variable": "${ABS_B_VAR}" } }, "direct_value": { "source_variable": "abs_blue" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "Mm-1" } } },
        "transmission_red": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "trans_red": { "source_type": "device", "source_id": "${ABS_DRIVER}::${ABS_SN}", "source_variable": "${ABS_TRANS_R_VAR}" } }, "direct_value": { "source_variable": "trans_red" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "1" } } },
        "transmission_green": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "trans_green": { "source_type": "device", "source_id": "${ABS_DRIVER}::${ABS_SN}", "source_variable": "${ABS_TRANS_G_VAR}" } }, "direct_value": { "source_variable": "trans_green" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "1" } } },
        "transmission_blue": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "trans_blue": { "source_type": "device", "source_id": "${ABS_DRIVER}::${ABS_SN}", "source_variable": "${ABS_TRANS_B_VAR}" } }, "direct_value": { "source_variable": "trans_blue" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "1" } } },
        "tap_sample_temperature": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "sample_T": { "source_type": "device", "source_id": "${ABS_DRIVER}::${ABS_SN}", "source_variable": "${ABS_TEMP_VAR}" } }, "direct_value": { "source_variable": "sample_T" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "degrees_C" } } },
        "tap_flow_rate": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "flow_rate": { "source_type": "device", "source_id": "${ABS_DRIVER}::${ABS_SN}", "source_variable": "${ABS_FLOW_VAR}" } }, "direct_value": { "source_variable": "flow_rate" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "SLPM" } } },
        "tap_active_spot": { "type": "int", "shape": ["time"], "map_type": "direct", "source": { "active_spot": { "source_type": "device", "source_id": "${ABS_DRIVER}::${ABS_SN}", "source_variable": "${ABS_SPOT_VAR}" } }, "direct_value": { "source_variable": "active_spot" }, "variableset": "main", "index_method": ["last"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "spot" } } }
      }
    }
  }

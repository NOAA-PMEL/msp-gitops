[
  {
    "version": "envds.sampling.system/v1",
    "kind": "PlatformVariableMap",
    "metadata": { "name": "varmap_primary_abs", "sampling_namespace": "${SAMPLING_NAMESPACE}", "platform": "${ENVOPS_PLATFORM_REF}", "valid_config_time": "${ABS_REVISION_TIME}", "revision": 1 },
    "data": {

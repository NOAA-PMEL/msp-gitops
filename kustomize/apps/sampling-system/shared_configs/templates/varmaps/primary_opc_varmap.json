[
  {
    "version": "envds.sampling.system/v1",
    "kind": "PlatformVariableMap",
    "metadata": { "name": "varmap_primary_opc", "sampling_namespace": "${SAMPLING_NAMESPACE}", "platform": "${ENVOPS_PLATFORM_REF}", "valid_config_time": "${OPC_REVISION_TIME}", "revision": 1 },
    "data": {
      "attributes": { "variablemap_type": "Sensor", "valid_config_time": "${OPC_REVISION_TIME}" },
      "variablesets": { 
        "sizing": { "index": { "index_type": "time", "index_value": ${SIZING_VARSET_TIMEBASE} }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" } } },
        "main": { "index": { "index_type": "time", "index_value": ${MAIN_VARSET_TIMEBASE} }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" } } } 
      },
      "variables": {
        "opc_diameter": { "type": "float", "shape": ["time", "diameter"], "map_type": "direct", "source": { "dp": { "source_type": "device", "source_id": "${OPC_DRIVER}::${OPC_SN}", "source_variable": "${OPC_DIA_VAR}" } }, "direct_value": { "source_variable": "dp" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "um" } } },
        "opc_particle_counts": { "type": "int", "shape": ["time", "diameter"], "map_type": "direct", "source": { "counts": { "source_type": "device", "source_id": "${OPC_DRIVER}::${OPC_SN}", "source_variable": "${OPC_COUNTS_VAR}" } }, "direct_value": { "source_variable": "counts" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "count" } } },
        "opc_dN": { "type": "float", "shape": ["time", "diameter"], "map_type": "direct", "source": { "dn": { "source_type": "device", "source_id": "${OPC_DRIVER}::${OPC_SN}", "source_variable": "${OPC_DN_VAR}" } }, "direct_value": { "source_variable": "dn" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "cm-3" } } },
        "opc_dNdlogDp": { "type": "float", "shape": ["time", "diameter"], "map_type": "direct", "source": { "dndlogdp": { "source_type": "device", "source_id": "${OPC_DRIVER}::${OPC_SN}", "source_variable": "${OPC_DNDLOGDP_VAR}" } }, "direct_value": { "source_variable": "dndlogdp" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "cm-3" } } },
        "opc_intN": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "intn": { "source_type": "device", "source_id": "${OPC_DRIVER}::${OPC_SN}", "source_variable": "${OPC_INTN_VAR}" } }, "direct_value": { "source_variable": "intn" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "cm-3" } } },
        "opc_flow": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "flow": { "source_type": "device", "source_id": "${OPC_DRIVER}::${OPC_SN}", "source_variable": "${OPC_FLOW_VAR}" } }, "direct_value": { "source_variable": "flow" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "l min-1" } } },
        "opc_inlet_temperature": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "itemp": { "source_type": "device", "source_id": "${OPC_DRIVER}::${OPC_SN}", "source_variable": "${OPC_TEMP_VAR}" } }, "direct_value": { "source_variable": "itemp" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "degrees_C" } } },
        "opc_pressure": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "press": { "source_type": "device", "source_id": "${OPC_DRIVER}::${OPC_SN}", "source_variable": "${OPC_PRES_VAR}" } }, "direct_value": { "source_variable": "press" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "hPa" } } }
      }
    }
  }
]
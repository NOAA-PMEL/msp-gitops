[
  {
    "version": "envds.sampling.system/v1",
    "kind": "PlatformVariableMap",
    "metadata": { "name": "varmap_primary_smps", "sampling_namespace": "${SAMPLING_NAMESPACE}", "platform": "${ENVOPS_PLATFORM_REF}", "valid_config_time": "${SMPS_REVISION_TIME}", "revision": 2},
    "data": {
      "attributes": { "variablemap_type": "Sensor", "valid_config_time": "${SMPS_REVISION_TIME}" },
      "variablesets": { 
        "sizing": { "index": { "index_type": "time", "index_value": ${SIZING_VARSET_TIMEBASE} }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" } } },
        "main": { "index": { "index_type": "time", "index_value": ${SMPS_MAIN_VARSET_TIMEBASE} }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" } } } 
      },
      "variables": {
        "smps_diameter": { "type": "float", "shape": ["time", "diameter"], "map_type": "direct", "source": { "dp": { "source_type": "device", "source_id": "${SMPS_DRIVER}::${SMPS_SN}", "source_variable": "${SMPS_DIA_VAR}" } }, "direct_value": { "source_variable": "dp" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "um" } } },
        "smps_dN": { "type": "float", "shape": ["time", "diameter"], "map_type": "direct", "source": { "dn": { "source_type": "device", "source_id": "${SMPS_DRIVER}::${SMPS_SN}", "source_variable": "${SMPS_DN_VAR}" } }, "direct_value": { "source_variable": "dn" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "cm-3" } } },
        "smps_dNdlogDp": { "type": "float", "shape": ["time", "diameter"], "map_type": "direct", "source": { "dndlogdp": { "source_type": "device", "source_id": "${SMPS_DRIVER}::${SMPS_SN}", "source_variable": "${SMPS_DNDLOGDP_VAR}" } }, "direct_value": { "source_variable": "dndlogdp" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "cm-3" } } },
        "smps_intN": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "intn": { "source_type": "device", "source_id": "${SMPS_DRIVER}::${SMPS_SN}", "source_variable": "${SMPS_INTN_VAR}" } }, "direct_value": { "source_variable": "intn" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "cm-3" } } },
        "smps_flow": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "flow": { "source_type": "device", "source_id": "${SMPS_DRIVER}::${SMPS_SN}", "source_variable": "${SMPS_FLOW_VAR}" } }, "direct_value": { "source_variable": "flow" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "l min-1" } } },
        "smps_inlet_temperature": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "itemp": { "source_type": "device", "source_id": "${SMPS_DRIVER}::${SMPS_SN}", "source_variable": "${SMPS_TEMP_VAR}" } }, "direct_value": { "source_variable": "itemp" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "degrees_C" } } },
        "smps_pressure": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "press": { "source_type": "device", "source_id": "${SMPS_DRIVER}::${SMPS_SN}", "source_variable": "${SMPS_PRES_VAR}" } }, "direct_value": { "source_variable": "press" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "mbar" } } }
      }
    }
  }
]
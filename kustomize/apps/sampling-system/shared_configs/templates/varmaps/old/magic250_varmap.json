[
  {
    "version": "envds.sampling.system/v1",
    "kind": "PlatformVariableMap",
    "metadata": {
      "name": "varmap_magic250",
      "sampling_namespace": "pmel.noaa.gov",
      "platform": "${ENVOPS_PLATFORM_REF}",
      "valid_config_time": "${MAGIC250_REVISION_TIME}"
    },
    "data": {
      "attributes": {
        "variablemap_type": "Platform",
        "platform": "${ENVOPS_PLATFORM_REF}"
      },
      "variablesets": {
        "main": { "index": { "index_type": "time", "index_value": 1 } }
      },
      "variables": {
        "cn": {
          "type": "float",
          "shape": ["time"],
          "map_type": "direct",
          "source": { "concentration": { "source_type": "device", "source_id": "AerosolDynamics::MAGIC250::${MAGIC250_SN}", "source_variable": "concentration" } },
          "direct_value": { "source_variable": "concentration" },
          "variableset": "main",
          "index_method": ["round", "average"],
          "fill_strategy": { "method": "none" },
          "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "cm-3" } }
        },
        "cn_flow": {
          "type": "float",
          "shape": ["time"],
          "map_type": "direct",
          "source": { "flow": { "source_type": "device", "source_id": "AerosolDynamics::MAGIC250::${MAGIC250_SN}", "source_variable": "flow" } },
          "direct_value": { "source_variable": "flow" },
          "variableset": "main",
          "index_method": ["round", "average"],
          "fill_strategy": { "method": "none" },
          "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "l min-1" } }
        }
      }
    }
  }
]
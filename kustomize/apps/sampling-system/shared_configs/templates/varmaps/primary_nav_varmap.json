        "platform_pitch": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "pitch": { "source_type": "device", "source_id": "${NAV_DRIVER}::${NAV_SN}", "source_variable": "${NAV_PITCH_VAR}" } }, "direct_value": { "source_variable": "pitch" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "operations-controller, data-server" }, "units": { "type": "string", "data": "degrees" } } },

[
  {
    "version": "envds.sampling.system/v1",
    "kind": "PlatformVariableMap",
    "metadata": { "name": "varmap_primary_aps", "sampling_namespace": "${SAMPLING_NAMESPACE}", "platform": "${ENVOPS_PLATFORM_REF}", "valid_config_time": "${APS_REVISION_TIME}", "revision": 1 },
    "data": {
      "attributes": { "variablemap_type": "Sensor", "valid_config_time": "${APS_REVISION_TIME}" },
      "variablesets": { 
        "sizing": { "index": { "index_type": "time", "index_value": ${SIZING_VARSET_TIMEBASE} }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" } } },
        "main": { "index": { "index_type": "time", "index_value": ${MAIN_VARSET_TIMEBASE} }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" } } } 
      },
      "variables": {
        "aps_diameter": { "type": "float", "shape": ["time", "diameter"], "map_type": "direct", "source": { "dp": { "source_type": "device", "source_id": "${APS_DRIVER}::${APS_SN}", "source_variable": "${APS_DIA_VAR}" } }, "direct_value": { "source_variable": "dp" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "um" } } },
        "aps_particle_counts": { "type": "int", "shape": ["time", "diameter"], "map_type": "direct", "source": { "counts": { "source_type": "device", "source_id": "${APS_DRIVER}::${APS_SN}", "source_variable": "${APS_COUNTS_VAR}" } }, "direct_value": { "source_variable": "counts" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "count" } } },
        "aps_dN": { "type": "float", "shape": ["time", "diameter"], "map_type": "direct", "source": { "dn": { "source_type": "device", "source_id": "${APS_DRIVER}::${APS_SN}", "source_variable": "${APS_DN_VAR}" } }, "direct_value": { "source_variable": "dn" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "cm-3" } } },
        "aps_dNdlogDp": { "type": "float", "shape": ["time", "diameter"], "map_type": "direct", "source": { "dndlogdp": { "source_type": "device", "source_id": "${APS_DRIVER}::${APS_SN}", "source_variable": "${APS_DNDLOGDP_VAR}" } }, "direct_value": { "source_variable": "dndlogdp" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "cm-3" } } },
        "aps_intN": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "intn": { "source_type": "device", "source_id": "${APS_DRIVER}::${APS_SN}", "source_variable": "${APS_INTN_VAR}" } }, "direct_value": { "source_variable": "intn" }, "variableset": "sizing", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "cm-3" } } },
        "aps_total_flow": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "tflow": { "source_type": "device", "source_id": "${APS_DRIVER}::${APS_SN}", "source_variable": "${APS_TFLOW_VAR}" } }, "direct_value": { "source_variable": "tflow" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "l min-1" } } },
        "aps_sheath_flow": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "sflow": { "source_type": "device", "source_id": "${APS_DRIVER}::${APS_SN}", "source_variable": "${APS_SFLOW_VAR}" } }, "direct_value": { "source_variable": "sflow" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "l min-1" } } },
        "aps_inlet_temperature": { "type": "float", "shape": ["time"], "map_type": "direct", "source": { "itemp": { "source_type": "device", "source_id": "${APS_DRIVER}::${APS_SN}", "source_variable": "${APS_TEMP_VAR}" } }, "direct_value": { "source_variable": "itemp" }, "variableset": "main", "index_method": ["round", "average"], "fill_strategy": { "method": "none" }, "attributes": { "evaluate_by": { "type": "string", "data": "local-controller, data-server" }, "units": { "type": "string", "data": "degrees_C" } } }
      }
    }
  }
]
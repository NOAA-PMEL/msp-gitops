[
  {
    "version": "envds.apps.sampling-system/v1",
    "kind": "Deployment",
    "metadata": {
      "name": "${ENVOPS_DEPLOYMENT_REF}",
      "sampling_namespace": "pmel.noaa.gov"
    },
    "revision-time": "${DEPLOYMENT_REVISION_TIME}",
    "data": {
      "display_name": "${ENVOPS_DEPLOYMENT_DISPLAY_NAME}",
      "description": "Internal deployment of the payload package into its host container/enclosure.",
      "platform_ref": "${ENVOPS_PLATFORM_REF}",
      "host_platform_ref": "${ENVOPS_HOST_PLATFORM_REF}",
      
      "planned_start_time": "${DEPLOYMENT_START_TIME}",
      "planned_end_time": "${DEPLOYMENT_END_TIME}"
    }
  }
]
{
  "id": "san_hnl.aerosol_sizing.a1",
  "type": "dataset-definition",
  "format": {
    "filetype": "nc",
    "standard": "DOE/ARM a1"
  },
  "timebase": {
    "record_frequency_sec": 300,
    "file_frequency": "daily"
  },
  "conventions": {
    "name": "CF-1.8",
    "featureType": "timeSeries"
  },
  "attributes": {
    "comment": "Aerosol sizing dataset. Contains combined log-normal size distributions.",
    "particle_size_range": "10nm - 20um"
  },
  "variables": [

{
  "id": "san_hnl.aerosol_optics.a1",
  "type": "dataset-definition",
  "format": {
    "filetype": "nc",
    "standard": "DOE/ARM a1"
  },
  "timebase": {
    "record_frequency_sec": 1,
    "file_frequency": "daily"
  },
  "conventions": {
    "name": "CF-1.8",

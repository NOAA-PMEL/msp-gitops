{
    "attributes": {
        "make": {"type": "string", "data": "ACOEM"},
        "model": {"type": "string", "data": "Aurora3000"},
        "description": {"type": "string", "data": "Three wavelength integrating nephelometer with backscatter"},
        "tags": {"type": "char", "data": "aerosol, nephelometer, scattering, backscatter, sensor"},
        "format_version": {"type": "char", "data": "2.0.0"},
        "variable_types": {"type": "string", "data": "main, setting, calibration, coordinate"},
        "device_type": {"type": "string", "data": "sensor"},
        "change_log": {"type": "string", "data": "2.0.0: Re-aligned variables for VI099 output. Added sampling_state, calibration_routine, and generic ext_valve_state for 3-way valve control."}
    },
    "dimensions": {
        "time": 0,
        "wavelength": 3
    },
    "variables": {
        "time": {
            "type": "str", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Time"}
        },
        "wavelength": {
            "type": "int",
            "shape": ["wavelength"],
            "attributes": {
                "variable_type": {"type": "string", "data": "coordinate"},
                "long_name": {"type": "char", "data": "LED Centroid Wavelength"},
                "units": {"type": "char", "data": "nm"},
                "data": [635, 525, 450]
            }
        },
        "wavelength_label": {
            "type": "str",
            "shape": ["wavelength"],
            "attributes": {
                "variable_type": {"type": "string", "data": "coordinate"},
                "long_name": {"type": "char", "data": "Wavelength Color Alias"},
                "data": ["red", "green", "blue"]
            }
        },
        "sampling_state": {
            "type": "str", "shape": ["time"],
            "attributes": {
                "variable_type": "setting",
                "long_name": "Instrument Operational State",
                "allowed_values": "idle, sampling, calibration, maintenance",
                "default_value": {"type": "string", "data": "idle"}
            }
        },
        "calibration_routine": {
            "type": "str", "shape": ["time"],
            "attributes": {
                "variable_type": "setting",
                "long_name": "Specific Calibration to Execute",
                "allowed_values": "none, zero_cal, span_cal_co2, zero_check, span_check",
                "default_value": {"type": "string", "data": "none"}
            }
        },
        "ext_valve_state": {
            "type": "str", "shape": ["time"],
            "attributes": {
                "variable_type": "setting",
                "long_name": "External 3-Way Valve Position",
                "allowed_values": "position_0, position_1",
                "default_value": {"type": "string", "data": "position_0"}
            }
        },
        "aurora_date": {
            "type": "str", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Internal Date"}
        },
        "aurora_time": {
            "type": "str", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Internal Time"}
        },
        "scat_coef_ch1_red": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Channel 1 Scattering (Red)", "units": "Mm-1"}
        },
        "scat_coef_ch2_green": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Channel 2 Scattering (Green)", "units": "Mm-1"}
        },
        "scat_coef_ch3_blue": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Channel 3 Scattering (Blue)", "units": "Mm-1"}
        },
        "backscatter_ch1_red": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Channel 1 Backscatter (Red)", "units": "Mm-1"}
        },
        "backscatter_ch2_green": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Channel 2 Backscatter (Green)", "units": "Mm-1"}
        },
        "backscatter_ch3_blue": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Channel 3 Backscatter (Blue)", "units": "Mm-1"}
        },
        "sample_T": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Sample Temperature", "units": "degrees_C"}
        },
        "enclosure_T": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Enclosure Temperature", "units": "degrees_C"}
        },
        "rh": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Relative Humidity", "units": "%"}
        },
        "pressure": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Barometric Pressure", "units": "mbar"}
        },
        "major_state": {
            "type": "int", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Major State Code"}
        },
        "DIO_state": {
            "type": "str", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "DIO Hex State"}
        }
    }
}
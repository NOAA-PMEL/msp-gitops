{
    "attributes": {
        "make": {"type": "string", "data": "ACOEM"},
        "model": {"type": "string", "data": "Aurora3000"},
        "description": {"type": "string", "data": "Three wavelength integrating nephelometer with backscatter"},
        "tags": {"type": "char", "data": "aerosol, nephelometer, scattering, backscatter, sensor"},
        "format_version": {"type": "char", "data": "2.1.0"},
        "variable_types": {"type": "string", "data": "main, setting, calibration, coordinate"},
        "device_type": {"type": "string", "data": "sensor"},
        "change_log": {"type": "string", "data": "2.1.0: fix data field in wl and wl_label; 2.0.0: Re-aligned variables for VI099 output. Added sampling_state, calibration_routine, and generic ext_valve_state for 3-way valve control."}
    },
    "dimensions": {
        "time": 0,
        "wavelength": 3
    },
    "variables": {
        "time": {
            "type": "str", "shape": ["time"],
            "attributes": {
                "variable_type": {"type": "string", "data": "main"}, 
                "long_name": {"type": "string", "data": "Time"}
            }
        },
        "wavelength": {
            "type": "int",
            "shape": ["wavelength"],
            "attributes": {
                "variable_type": {"type": "string", "data": "coordinate"},
                "long_name": {"type": "char", "data": "LED Centroid Wavelength"},
                "units": {"type": "char", "data": "nm"},
                "data": {"type": "int", "data": [635, 525, 450]}
            }
        },
        "wavelength_label": {
            "type": "str",
            "shape": ["wavelength"],
            "attributes": {
                "variable_type": {"type": "string", "data": "coordinate"},
                "long_name": {"type": "char", "data": "Wavelength Color Alias"},
                "data": {"type": "str", "data": ["red", "green", "blue"]}
            }
        },
        "sampling_state": {
            "type": "str", "shape": ["time"],
            "attributes": {
                "variable_type": {"type": "string", "data": "setting"},
                "long_name": {"type": "string", "data": "Instrument Operational State"},
                "allowed_values": {"type": "string", "data": "idle, sampling, calibration, maintenance"},
                "default_value": {"type": "string", "data": "idle"}
            }
        },
        "calibration_routine": {
            "type": "str", "shape": ["time"],
            "attributes": {
                "variable_type": {"type": "string", "data": "setting"},
                "long_name": {"type": "string", "data": "Specific Calibration to Execute"},
                "allowed_values": {"type": "string", "data": "none, zero_cal, span_cal_co2, zero_check, span_check"},
                "default_value": {"type": "string", "data": "none"}
            }
        },
        "ext_valve_state": {
            "type": "str", "shape": ["time"],
            "attributes": {
                "variable_type": {"type": "string", "data": "setting"},
                "long_name": {"type": "string", "data": "External 3-Way Valve Position"},
                "allowed_values": {"type": "string", "data": "position_0, position_1"},
                "default_value": {"type": "string", "data": "position_0"}
            }
        },
        "aurora_date": {
            "type": "str", "shape": ["time"],
            "attributes": {"variable_type": {"type": "string", "data": "main"}, "long_name": {"type": "string", "data": "Internal Date"}}
        },

        },
        "backscatter_ch3_blue": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": {"type": "string", "data": "main"}, "long_name": {"type": "string", "data": "Channel 3 Backscatter (Blue)"}, "units": {"type": "string", "data": "Mm-1"}}

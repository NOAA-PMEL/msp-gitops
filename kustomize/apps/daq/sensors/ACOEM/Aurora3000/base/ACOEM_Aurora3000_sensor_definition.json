        },
        "pressure": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": {"type": "string", "data": "main"}, "long_name": {"type": "string", "data": "Barometric Pressure"}, "units": {"type": "string", "data": "mbar"}}

{
    "attributes": {
        "make": {"type": "string", "data": "TSI"},
        "model": {"type": "string", "data": "APS3321"},
        "format_version": {"type": "char", "data": "2.2.0"},
        "variable_types": {"type": "string", "data": "main, setting, calibration"},
        "device_type": {"type": "string", "data": "sensor"}
    },
    "dimensions": {"time": 0, "diameter": 52, "channel": 64},
    "variables": {
        "time": {
            "type": "str", "shape": ["time"], 
            "attributes": {"variable_type": "main"}
        },
        "sampling_state": {
            "type": "str", "shape": ["time"],
            "attributes": {
                "variable_type": "setting",
                "long_name": "Instrument Operational State",
                "allowed_values": "idle, sampling, calibration, maintenance, error",
                "default_value": "sampling"
            }
        },
        "calibration_routine": {
            "type": "str", "shape": ["time"],
            "attributes": {
                "variable_type": "setting",
                "long_name": "Specific Calibration to Execute",
                "allowed_values": "none, zero_check",
                "default_value": "none"
            }
        },
        "ffff": {
            "type": "str", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Status Flags (4 digit hex)"}
        },
        "stime": {
            "type": "int", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Sample Time", "units": "seconds"}
        },
        "dtime": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Dead Time", "units": "milliseconds"}
        },
        "evt1": {
            "type": "int", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Single Hump Events", "units": "count"}
        },
        "evt3": {
            "type": "int", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "3+ Hump Events", "units": "count"}
        },
        "evt4": {
            "type": "int", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Timer Overflow Events", "units": "count"}
        },
        "total": {
            "type": "int", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Total Particles Measured", "units": "count"}
        },
        "particle_counts": {
            "type": "int", "shape": ["time", "diameter"],
            "attributes": {"variable_type": "main", "long_name": "Diameter Channel Counts", "units": "count"}
        },
        "particle_counts_accum": {
            "type": "int", "shape": ["time", "channel"],
            "attributes": {"variable_type": "main", "long_name": "Accumulated Particle Counts", "units": "count"}
        },
        "particle_counts_ss": {
            "type": "int", "shape": ["time", "diameter"],
            "attributes": {"variable_type": "main", "long_name": "Side Scatter Particle Counts", "units": "count"}
        },
        "diameter": {
            "type": "float", "shape": ["diameter"],
            "attributes": {"variable_type": "main", "long_name": "Aerodynamic Diameter", "units": "um"}
        },
        "channel": {
            "type": "int", "shape": ["channel"],
            "attributes": {"variable_type": "main", "long_name": "Channel Number"}
        },
        "dN": {
            "type": "float", "shape": ["time", "diameter"],
            "attributes": {"variable_type": "main", "long_name": "Particle Concentration", "units": "#/cm3"}
        },
        "dlogDp": {
            "type": "float", "shape": ["time", "diameter"],
            "attributes": {"variable_type": "main", "long_name": "Log Bin Width"}
        },
        "dNdlogDp": {
            "type": "float", "shape": ["time", "diameter"],
            "attributes": {"variable_type": "main", "long_name": "Normalized Particle Concentration", "units": "#/cm3"}
        },
        "intN": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Total Integrated Concentration", "units": "#/cm3"}
        },
        "bpress": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Barometric Inlet Pressure", "units": "mbar"}
        },
        "tflow": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Total Flow", "units": "lpm"}
        },
        "sflow": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Sheath Flow", "units": "lpm"}
        },
        "itemp": {
            "type": "float", "shape": ["time"],
            "attributes": {"variable_type": "main", "long_name": "Inlet Temperature", "units": "degrees_C"}
        }
    }
}
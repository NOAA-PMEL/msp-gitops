[
    {
        "version": "envds.sampling.operations/v1",
        "kind": "SamplingState",
        "metadata": {
            "name": "in_sector",
            "sampling_namespace": "${SAMPLING_NAMESPACE}/${ENVOPS_DEPLOYMENT_REF}",
            "valid_config_time": "${STATES_REVISION_TIME}",
            "revision": 1
        },
        "requirements": [
            {
                "kind": "SamplingCondition",
                "name": "sampling_wind_direction_limit",
                "required_time_to_transition": {
                    "to_become_false": 5,
                    "to_become_true": 10
                }
            },
            {
                "kind": "SamplingCondition",
                "name": "sampling_wind_speed_limit",
                "required_time_to_transition": {
                    "to_become_false": 5,
                    "to_become_true": 10
                }
            }
        ]
    }
]
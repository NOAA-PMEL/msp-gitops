[
    {
        "version": "envds.sampling.operations/v1",
        "kind": "SamplingCondition",
        "metadata": {
            "name": "cn_limit",
            "sampling_namespace": "${SAMPLING_NAMESPACE}/${ENVOPS_DEPLOYMENT_REF}",
            "valid_config_time": "${CN_LIMIT_REVISION_TIME}",
            "revision": 1
        },
        "sources": { 
            "cn": { "variablemap_name": "${CN_VARIABLEMAP}", "variableset_name": "${CN_VARIABLESET}", "variable": "${CN_VARIABLE}" } 
        },
        "criteria": { 
            "all": [ 
                { 
                    "criterion_class": "LimitMinMax", 
                    "sources": ["cn"], 
                    "max_val": ${CN_MAX_LIMIT}, 
                    "min_val": ${CN_MIN_LIMIT}, 
                    "true_if": "inside" 
                } 
            ] 
        }
    }
]
[
    {
        "version": "envds.sampling.operations/v1",
        "kind": "SamplingCondition",
        "metadata": {
            "name": "beacons_at_sea",
            "sampling_namespace": "${SAMPLING_NAMESPACE}/${ENVOPS_DEPLOYMENT_REF}",
            "valid_config_time": "${CONDITIONS_REVISION_TIME}"
        },
        "sources": {
            "gps_latitude": {
                "variablemap_name": "${NAV_VARMAP}",
                "variableset_name": "main",
                "variable": "latitude"
            },
            "gps_longitude": {
                "variablemap_name": "${NAV_VARMAP}",
                "variableset_name": "main",
                "variable": "longitude"
            }
        },
        "criteria": {
            "all": [
                {
                    "criterion_class": "LimitMinMax",
                    "label": "Valid_Latitude_Check",
                    "true_if": "inside",
                    "sources": ["gps_latitude"],
                    "min_val": -90.0,
                    "max_val": 90.0
                },
                {
                    "criterion_class": "LimitMinMax",
                    "label": "Valid_Longitude_Check",
                    "true_if": "inside",
                    "sources": ["gps_longitude"],
                    "min_val": -180.0,
                    "max_val": 180.0
                },
                {
                    "criterion_class": "LatLonRegionLocation",
                    "label": "San_Diego_Pasha_Wharf_and_Harbor_Entrance_Buffer",
                    "true_if": "outside",
                    "sources": [
                        "gps_latitude",
                        "gps_longitude"
                    ],
                    "coordinates": {
                        "latitude": "gps_latitude",
                        "longitude": "gps_longitude"
                    },
                    "region": [
                        { "latitude": 32.750, "longitude": -117.270 },
                        { "latitude": 32.750, "longitude": -117.100 },
                        { "latitude": 32.580, "longitude": -117.100 },
                        { "latitude": 32.580, "longitude": -117.270 }
                    ]
                },
                {
                    "criterion_class": "LatLonRegionLocation",
                    "label": "Port_of_Long_Beach_and_Breakwater_Approach_Buffer",

[
    {
        "version": "envds.sampling.operations/v1",
        "kind": "SamplingCondition",
        "metadata": {
            "name": "at_pmel",
            "sampling_namespace": "${SAMPLING_NAMESPACE}/${ENVOPS_DEPLOYMENT_REF}",
            "valid_config_time": "${GEOFENCE_REVISION_TIME}",
            "revision": 1
        },
        "sources": {
            "gps_latitude": { "variablemap_name": "${NAV_VARIABLEMAP}", "variableset_name": "${NAV_VARIABLESET}", "variable": "${NAV_LAT_VARIABLE}" },
            "gps_longitude": { "variablemap_name": "${NAV_VARIABLEMAP}", "variableset_name": "${NAV_VARIABLESET}", "variable": "${NAV_LON_VARIABLE}" }
        },
        "criteria": {
            "all": [
                {
                    "criterion_class": "LatLonRegionLocation",
                    "label": "NOAA/PMEL_Diamond_Geofence",
                    "true_if": "inside",
                    "sources": ["gps_latitude", "gps_longitude"],
                    "coordinates": { "latitude": "gps_latitude", "longitude": "gps_longitude" },
                    "region": [
                        {"latitude": 47.6950, "longitude": -122.2570},  
                        {"latitude": 47.6850, "longitude": -122.2450},  
                        {"latitude": 47.6750, "longitude": -122.2570},  
                        {"latitude": 47.6850, "longitude": -122.2690}   
                    ]
                }
            ]
        }
    }
]
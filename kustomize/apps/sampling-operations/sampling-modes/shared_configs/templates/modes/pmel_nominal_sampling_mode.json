[
    {
        "version": "envds.sampling.modes/v1",
        "kind": "SamplingMode",
        "metadata": {
            "name": "pmel_nominal_sampling",
            "sampling_namespace": "${SAMPLING_NAMESPACE}/${ENVOPS_DEPLOYMENT_REF}",
            "valid_config_time": "${PMEL_NOMINAL_MODE_REV_TIME}",
            "revision": 1
        },
        "requirements": [
            { "kind": "SamplingState", "name": "pmel_nominal_location" },
            { "kind": "SamplingState", "name": "nominal_concentrations" },
            { "kind": "SamplingState", "name": "cpc_hardware_ready" }
        ],
        "actions": {
            "true": [],
            "false": [ 
                { 
                    "kind": "SamplingAction", 
                    "name": "pmel_disable_cpc_power" 
                } 
            ]
        }
    }
]
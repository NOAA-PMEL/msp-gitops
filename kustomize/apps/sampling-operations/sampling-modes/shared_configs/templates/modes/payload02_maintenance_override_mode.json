[
    {
        "version": "envds.sampling.modes/v1",
        "kind": "SamplingMode",
        "metadata": {
            "name": "maintenance_override",
            "sampling_namespace": "${SAMPLING_NAMESPACE}/${ENVOPS_DEPLOYMENT_REF}",
            "valid_config_time": "${MODES_REVISION_TIME}",
            "revision": 1
        },
        "requirements": [
            {
                "kind": "SamplingState",
                "name": "maintenance_active"
            }
        ],
        "actions": {
            "true": [
                {
                    "kind": "SamplingAction",
                    "name": "turn_off_absorb"
                },
                {
                    "kind": "SamplingAction",
                    "name": "turn_off_neph"
                },
                {
                    "kind": "SamplingAction",
                    "name": "turn_off_tec"
                },
                {
                    "kind": "SamplingAction",
                    "name": "turn_off_24v_bus"
                }
            ],
            "false": []
        }
    }
]